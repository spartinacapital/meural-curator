class MeuralClient:
    def __init__(self, email, password):
        self.email = email
        self.password = password
        self.token = None
        self._authenticate()

    def _authenticate(self):
        """Authenticate via AWS Cognito to get an access token."""
        print("  Authenticating with Meural...")
        client = boto3.client(
            "cognito-idp",
            region_name=COGNITO_REGION,
            aws_access_key_id="dummy",
            aws_secret_access_key="dummy",
        )
        resp = client.initiate_auth(
            ClientId=COGNITO_CLIENT_ID,
            AuthFlow="USER_PASSWORD_AUTH",
            AuthParameters={
                "USERNAME": self.email,
                "PASSWORD": self.password,
            },
        )
        self.token = resp["AuthenticationResult"]["AccessToken"]
        print("  Authenticated.")

    def _headers(self):
        return {
            "Authorization": f"Token {self.token}",
            "x-meural-api-version": "3",
        }

    def _get(self, path, params=None):
        r = requests.get(MEURAL_API_BASE + path, headers=self._headers(), params=params)
        r.raise_for_status()
        return r.json().get("data", r.json())

    def _post(self, path, data=None, files=None, json_body=None):
        r = requests.post(
            MEURAL_API_BASE + path,
            headers=self._headers(),
            data=data,
            files=files,
            json=json_body,
        )
        r.raise_for_status()
        return r.json().get("data", r.json())

    def get_user(self):
        return self._get("user")

    def get_devices(self):
        return self._get("user/devices", params={"count": 50, "page": 1})

    def get_galleries(self):
        return self._get("user/galleries", params={"count": 100, "page": 1})

    def create_gallery(self, name, orientation="vertical"):
        print(f"  Creating gallery: {name}")
        return self._post("galleries", data={"name": name, "orientation": orientation})

    def upload_image(self, filepath):
        """Upload an image file with automatic re-auth on 401. Returns the item data dict."""
        filename = os.path.basename(filepath)
        content_type = "image/jpeg"
        if filepath.lower().endswith(".png"):
            content_type = "image/png"
        elif filepath.lower().endswith(".heic"):
            content_type = "image/heic"

        for attempt in range(2):
            with open(filepath, "rb") as f:
                r = requests.post(
                    MEURAL_API_BASE + "items",
                    headers=self._headers(),
                    files={"image": (filename, f, content_type)},
                )
            if r.status_code == 401 and attempt == 0:
                self._authenticate()
                continue
            r.raise_for_status()
            return r.json().get("data", r.json())

    def add_item_to_gallery(self, gallery_id, item_id):
        return self._post(f"galleries/{gallery_id}/items/{item_id}")

    def load_gallery_on_device(self, device_id, gallery_id):
        return self._post(f"devices/{device_id}/galleries/{gallery_id}")


# ---------------------------------------------------------------------------
# Photo query engine (wraps osxphotos)
# ---------------------------------------------------------------------------

class PhotoQueryEngine:
    def __init__(self, config):
        print("  Loading Photos library...")
        self.db = osxphotos.PhotosDB()
        self.config = config
        self.children_dobs = {}
        for name, dob_str in config.get("children", {}).items():
            self.children_dobs[name.lower()] = datetime.strptime(dob_str, "%Y-%m-%d").date()
        print(f"  Loaded {len(self.db.photos())} photos.")

    def get_available_persons(self):
        return [p for p in self.db.persons if p != "_UNKNOWN_"]

    def query_photos(
        self,
        persons=None,
        min_age_years=None,
        max_age_years=None,
        person_for_age=None,
        date_start=None,
        date_end=None,
        labels=None,
        holidays=None,
        min_score=None,
        max_photos=None,
        distribution_strategy="even_time",
        month_filter=None,
        orientation_filter=None,
    ):
        """
        Query photos with flexible filters. Returns list of PhotoInfo objects.
        orientation_filter: "landscape", "portrait", or None
        """
        # Start with person filter if specified
        if persons:
            photos = []
            for person in persons:
                photos.extend(self.db.photos(persons=[person]))
            # Deduplicate by UUID
            seen = set()
            unique = []
            for p in photos:
                if p.uuid not in seen:
                    seen.add(p.uuid)
                    unique.append(p)
            photos = unique
        else:
            photos = list(self.db.photos())

        # Filter by age (requires a person to calculate age from)
        if min_age_years is not None or max_age_years is not None:
            age_persons = person_for_age if person_for_age else (persons or [])
            photos = self._filter_by_age(photos, age_persons, min_age_years, max_age_years)

            # Supplement with newborn photos if the age range includes early months
            if persons and min_age_years is not None and min_age_years <= 0.5:
                existing_uuids = {p.uuid for p in photos}
                for person in persons:
                    newborn = self._find_newborn_photos(person)
                    # Apply orientation filter to newborn photos too
                    if orientation_filter == "landscape":
                        newborn = [p for p in newborn if p.width and p.height and p.width > p.height]
                    elif orientation_filter == "portrait":
                        newborn = [p for p in newborn if p.width and p.height and p.height > p.width]
                    for p in newborn:
                        if p.uuid not in existing_uuids:
                            photos.append(p)
                            existing_uuids.add(p.uuid)

        # Filter by date range
        if date_start or date_end:
            photos = self._filter_by_date(photos, date_start, date_end)

        # Filter by month, labels, and holidays using OR logic
        # (a Christmas photo might match via holiday tag OR label OR month)
        has_thematic_filter = month_filter or labels or holidays
        if has_thematic_filter:
            labels_lower = [l.lower() for l in labels] if labels else []
            holidays_lower = [h.lower() for h in holidays] if holidays else []
            filtered = []
            for p in photos:
                matched = False
                # Match by month
                if month_filter and p.date and p.date.month in month_filter:
                    matched = True
                # Match by label
                if not matched and labels_lower and p.labels:
                    if any(l.lower() in labels_lower for l in p.labels):
                        matched = True
                # Match by holiday
                if not matched and holidays_lower:
                    si = p.search_info_normalized
                    if si and si.holidays:
                        if any(h in holidays_lower for h in si.holidays):
                            matched = True
                if matched:
                    filtered.append(p)
            photos = filtered

        # Filter by minimum score
        if min_score is not None:
            photos = [p for p in photos if p.score and p.score.overall and p.score.overall >= min_score]

        # Filter out screenshots, selfies, and videos (Meural only accepts images)
        photos = [p for p in photos if not p.screenshot and not p.selfie and p.isphoto]

        # Filter by orientation (landscape = wider than tall, portrait = taller than wide)
        if orientation_filter == "landscape":
            photos = [p for p in photos if p.width and p.height and p.width > p.height]
        elif orientation_filter == "portrait":
            photos = [p for p in photos if p.width and p.height and p.height > p.width]

        # Apply distribution and selection
        if max_photos and len(photos) > max_photos:
            photos = self._distribute_and_select(photos, max_photos, distribution_strategy)

        return photos

    def _find_newborn_photos(self, person, max_age_months=6):
        """
        Find probable newborn photos for a child that face recognition missed.
        Looks for photos with 'Baby' label near the child's birthdate where the
        child isn't recognized (tagged as _UNKNOWN_ or no person).
        """
        dob = self.children_dobs.get(person.lower())
        if not dob:
            return []

        from datetime import timedelta
        window_start = dob
        window_end = dob + timedelta(days=max_age_months * 30)

        # Get all photos in the time window with 'Baby' label
        candidates = []
        for p in self.db.photos():
            if not p.date:
                continue
            photo_date = p.date.date() if hasattr(p.date, 'date') else p.date
            if photo_date < window_start or photo_date > window_end:
                continue
            if not p.labels or 'Baby' not in p.labels:
                continue
            if p.screenshot:
                continue

            # Include if: no person recognized, or _UNKNOWN_, or a family member
            # is in the photo (parent holding baby), but the child is not tagged
            person_names = [n.lower() for n in (p.persons or [])]
            if person.lower() not in person_names:
                # Exclude photos where a DIFFERENT known child is the baby
                # (check if another child's DOB is closer to this photo date)
                dominated_by_other = False
                for other_name, other_dob in self.children_dobs.items():
                    if other_name == person.lower():
                        continue
                    other_age_days = (photo_date - other_dob).days
                    this_age_days = (photo_date - dob).days
                    if 0 <= other_age_days <= max_age_months * 30 and other_age_days < this_age_days:
                        dominated_by_other = True
                        break
                if not dominated_by_other:
                    candidates.append(p)

        return candidates

    def query_per_person_distributed(self, persons, photos_per_person, min_age_years=None, max_age_years=None, min_score=0.3, orientation_filter=None):
        """
        Query photos for multiple persons, distributing evenly across each person's time range.
        Returns combined list.
        """
        all_selected = []
        for person in persons:
            person_photos = self.db.photos(persons=[person])
            person_photos = [p for p in person_photos if not p.screenshot and not p.selfie and p.isphoto]

            # Filter by orientation
            if orientation_filter == "landscape":
                person_photos = [p for p in person_photos if p.width and p.height and p.width > p.height]
            elif orientation_filter == "portrait":
                person_photos = [p for p in person_photos if p.width and p.height and p.height > p.width]

            if min_age_years is not None or max_age_years is not None:
                person_photos = self._filter_by_age(person_photos, [person], min_age_years, max_age_years)

                # Supplement with newborn photos if the age range includes early months
                if min_age_years is not None and min_age_years <= 0.5:
                    newborn = self._find_newborn_photos(person)
                    # Apply same orientation filter to newborn photos
                    if orientation_filter == "landscape":
                        newborn = [p for p in newborn if p.width and p.height and p.width > p.height]
                    elif orientation_filter == "portrait":
                        newborn = [p for p in newborn if p.width and p.height and p.height > p.width]
                    # Add newborn photos that aren't already in the set
                    existing_uuids = {p.uuid for p in person_photos}
                    added = 0
                    for p in newborn:
                        if p.uuid not in existing_uuids:
                            person_photos.append(p)
                            existing_uuids.add(p.uuid)
                            added += 1
                    if added:
                        print(f"    {person}: added {added} newborn photos via Baby label matching")

            if min_score is not None:
                person_photos = [p for p in person_photos if p.score and p.score.overall and p.score.overall >= min_score]

            if len(person_photos) > photos_per_person:
                person_photos = self._distribute_and_select(person_photos, photos_per_person, "even_time")

            print(f"    {person}: selected {len(person_photos)} photos")
            all_selected.extend(person_photos)

        return all_selected

    def _filter_by_age(self, photos, persons, min_age_years, max_age_years):
        """Filter photos where the photo date falls within the age range for any of the given persons."""
        filtered = []
        for p in photos:
            if not p.date:
                continue
            photo_date = p.date.date() if hasattr(p.date, 'date') else p.date
            for person in persons:
                dob = self.children_dobs.get(person.lower())
                if not dob:
                    continue
                age_days = (photo_date - dob).days
                age_years = age_days / 365.25
                if (min_age_years is None or age_years >= min_age_years) and \
                   (max_age_years is None or age_years <= max_age_years):
                    filtered.append(p)
                    break
        return filtered

    def _filter_by_date(self, photos, date_start, date_end):
        filtered = []
        for p in photos:
            if not p.date:
                continue
            photo_date = p.date.date() if hasattr(p.date, 'date') else p.date
            if date_start and photo_date < date_start:
                continue
            if date_end and photo_date > date_end:
                continue
            filtered.append(p)
        return filtered

    def _distribute_and_select(self, photos, max_photos, strategy):
        """Select max_photos distributed evenly across time, picking highest scored in each bucket."""
        if not photos:
            return []

        # Sort by date
        dated = [(p, p.date) for p in photos if p.date]
        dated.sort(key=lambda x: x[1])

        if not dated:
            return photos[:max_photos]

        # Create time buckets
        n_buckets = min(max_photos, len(dated))
        bucket_size = len(dated) / n_buckets
        selected = []

        for i in range(n_buckets):
            start_idx = int(i * bucket_size)
            end_idx = int((i + 1) * bucket_size)
            bucket = dated[start_idx:end_idx]
            if not bucket:
                continue
            # Pick the highest scored photo in this bucket
            best = max(bucket, key=lambda x: (x[0].score.overall if x[0].score and x[0].score.overall else 0))
            selected.append(best[0])

        return selected

    def export_photos(self, photos, dest_dir):
        """Export photos to a destination directory via PhotoScript (handles iCloud downloads)."""
        import photoscript

        exported = []
        failed = 0
        for i, photo in enumerate(photos):
            try:
                ps_photo = photoscript.Photo(photo.uuid)
                results = ps_photo.export(dest_dir)
                if results:
                    # Filter out videos (Live Photo video components, etc.)
                    image_exts = {".jpg", ".jpeg", ".png", ".heic", ".gif", ".tiff", ".bmp"}
                    img_results = [r for r in results if os.path.splitext(r)[1].lower() in image_exts]
                    if img_results:
                        exported.append(img_results[0])
                    else:
                        failed += 1
                else:
                    failed += 1
            except Exception as e:
                failed += 1
                if failed <= 3:
                    print(f"    Warning: Failed to export {photo.filename}: {e}")
            if (i + 1) % 10 == 0:
                print(f"    Exported {i+1}/{len(photos)} ({len(exported)} ok, {failed} failed)...")
        if failed:
            print(f"    {failed} photos could not be exported (may still be downloading from iCloud).")
        return exported


