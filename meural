def execute_plan(plan, engine):
    """Execute a query plan and return selected photos."""
    strategy = plan.get("strategy", "single_query")

    if strategy == "per_person_distributed":
        pp = plan["per_person"]
        return engine.query_per_person_distributed(
            persons=pp["persons"],
            photos_per_person=pp["photos_per_person"],
            min_age_years=pp.get("min_age_years"),
            max_age_years=pp.get("max_age_years"),
            min_score=pp.get("min_score", 0.3),
            orientation_filter=pp.get("orientation_filter"),
        )
    else:
        q = plan["query"]
        return engine.query_photos(
            persons=q.get("persons"),
            min_age_years=q.get("min_age_years"),
            max_age_years=q.get("max_age_years"),
            person_for_age=q.get("person_for_age"),
            date_start=date.fromisoformat(q["date_start"]) if q.get("date_start") else None,
            date_end=date.fromisoformat(q["date_end"]) if q.get("date_end") else None,
            labels=q.get("labels"),
            holidays=q.get("holidays"),
            min_score=q.get("min_score", 0.3),
            max_photos=q.get("max_photos", plan.get("total_photos", 100)),
            distribution_strategy=q.get("distribution_strategy", "even_time"),
            month_filter=q.get("month_filter"),
            orientation_filter=q.get("orientation_filter"),
        )


def upload_to_meural(meural, photos, engine, gallery_name, orientation="vertical", device_id=None):
    """Export photos and upload them to Meural, creating a gallery."""
    # Create gallery
    gallery_data = meural.create_gallery(gallery_name, orientation)
    gallery_id = gallery_data["id"]
    print(f"  Gallery created: {gallery_name} (ID: {gallery_id})")

    # Export and upload
    with tempfile.TemporaryDirectory() as tmpdir:
        print(f"  Preparing {len(photos)} photos for upload...")
        paths = engine.export_photos(photos, tmpdir)

        # Filter out any non-image files (videos etc.)
        image_exts = {".jpg", ".jpeg", ".png", ".heic", ".gif", ".tiff", ".bmp"}
        paths = [p for p in paths if os.path.splitext(p)[1].lower() in image_exts]

        # Re-authenticate right before uploading (token may have expired during export)
        meural._authenticate()

        uploaded = 0
        failed_paths = []
        print(f"  Uploading {len(paths)} photos to Meural...")
        for i, path in enumerate(paths):
            # Re-authenticate every 30 uploads to avoid token expiry
            if i > 0 and i % 30 == 0:
                meural._authenticate()

            success = False
            for attempt in range(3):
                try:
                    item_data = meural.upload_image(path)
                    item_id = item_data["id"]
                    meural.add_item_to_gallery(gallery_id, item_id)
                    uploaded += 1
                    success = True
                    break
                except requests.exceptions.HTTPError as e:
                    status = e.response.status_code if e.response is not None else 0
                    if status == 400:
                        # Bad file, don't retry
                        print(f"    Skipped {os.path.basename(path)}: not accepted by Meural")
                        break
                    elif status == 401:
                        meural._authenticate()
                    elif status in (502, 504) and attempt < 2:
                        time.sleep(2 * (attempt + 1))
                    else:
                        print(f"    Warning: Failed to upload {os.path.basename(path)}: {e}")
                        break
                except Exception as e:
                    print(f"    Warning: Failed to upload {os.path.basename(path)}: {e}")
                    break

            if not success:
                failed_paths.append(path)

            if (i + 1) % 10 == 0:
                print(f"    Uploaded {i+1}/{len(paths)} ({uploaded} succeeded)...")

        if failed_paths:
            print(f"  {len(failed_paths)} photos could not be uploaded.")

    # Load gallery on device if we know the device
    if device_id:
        print(f"  Loading gallery on device {device_id}...")
        try:
            meural.load_gallery_on_device(device_id, gallery_id)
            print(f"  Gallery loaded on device.")
        except Exception as e:
            print(f"  Note: Could not auto-load gallery on device ({e}).")
            print(f"  You can load it manually from the Meural app.")

    return gallery_id


def get_meural_password():
    """Get or prompt for Meural password."""
    creds = load_credentials()
    if creds.get("meural_password"):
        return creds["meural_password"]

    import getpass
    password = getpass.getpass("Enter your Meural (Netgear) account password: ")
    creds["meural_password"] = password
    save_credentials(creds)
    return password


def main():
    parser = argparse.ArgumentParser(
        description="Natural language photo curation for Meural frames",
        usage='meural "Create an album of Christmas pictures over the years"',
    )
    parser.add_argument("prompt", nargs="?", help="Natural language description of the album you want")
    parser.add_argument("--dry-run", action="store_true", help="Plan and select photos but don't upload to Meural")
    parser.add_argument("--no-preview", action="store_true", help="Skip the preview step and upload directly")
    parser.add_argument("--show-plan", action="store_true", help="Show the query plan Claude generates")
    parser.add_argument("--list-devices", action="store_true", help="List your Meural devices")
    parser.add_argument("--list-galleries", action="store_true", help="List your Meural galleries")
    parser.add_argument("--device", type=str, help="Meural device ID to load the gallery on")

    args = parser.parse_args()
    config = load_config()

    # Handle Meural-only commands
    if args.list_devices or args.list_galleries:
        password = get_meural_password()
        meural = MeuralClient(config["meural_email"], password)
        if args.list_devices:
            devices = meural.get_devices()
            print("\nYour Meural devices:")
            for d in devices:
                print(f"  ID: {d['id']}  Name: {d.get('name', 'unnamed')}  Status: {d.get('status', 'unknown')}")
        if args.list_galleries:
            galleries = meural.get_galleries()
            print("\nYour Meural galleries:")
            for g in galleries:
                print(f"  ID: {g['id']}  Name: {g.get('name', 'unnamed')}  Items: {g.get('itemCount', '?')}")
        return

    if not args.prompt:
        parser.print_help()
        return

    print(f'\n  Prompt: "{args.prompt}"\n')

    # Step 1: Load Photos library and get available metadata
    engine = PhotoQueryEngine(config)
    available_persons = engine.get_available_persons()

    # Step 2: Use Claude to interpret the prompt
    print("  Interpreting your request with Claude...")
    plan = plan_query(args.prompt, config, available_persons)

    if args.show_plan or args.dry_run:
        print(f"\n  Query plan:")
        print(f"  {json.dumps(plan, indent=2)}")
        print()

    print(f'  Album: {plan["gallery_name"]}')
    print(f'  Description: {plan.get("description", "")}')
    print(f'  Target: {plan.get("total_photos", "?")} photos\n')

    # Step 3: Execute the query
    print("  Selecting photos...")
    photos = execute_plan(plan, engine)
    print(f"  Selected {len(photos)} photos.\n")

    if not photos:
        print("  No photos matched the criteria. Try broadening your request.")
        return

    # Show date range of selected photos
    dates = sorted([p.date for p in photos if p.date])
    if dates:
        print(f"  Date range: {dates[0].strftime('%Y-%m-%d')} to {dates[-1].strftime('%Y-%m-%d')}")

    # Show score summary
    scores = [p.score.overall for p in photos if p.score and p.score.overall]
    if scores:
        print(f"  Quality scores: min={min(scores):.2f}, avg={sum(scores)/len(scores):.2f}, max={max(scores):.2f}")

    print()

    if args.dry_run:
        print("  Dry run - not uploading to Meural.")
        print(f"  Would create gallery: {plan['gallery_name']}")
        print(f"  Would upload {len(photos)} photos.")
        return

    # Step 4: Preview in Apple Photos and confirm
    if not args.no_preview:
        import photoscript
        import subprocess

        preview_name = f"Meural Preview - {plan['gallery_name']}"
        print(f"  Creating preview album in Photos: \"{preview_name}\"")

        photos_app = photoscript.PhotosLibrary()

        # Delete any existing preview album with same name (use AppleScript directly to avoid bug)
        try:
            import subprocess as _sp
            _sp.run(["osascript", "-e", f'''
                tell application "Photos"
                    set matchingAlbums to (every album whose name is "{preview_name}")
                    repeat with a in matchingAlbums
                        delete a
                    end repeat
                end tell
            '''], capture_output=True, timeout=15)
        except Exception:
            pass

        album = photos_app.create_album(preview_name)
        original_uuids = {p.uuid for p in photos}
        ps_photos = [photoscript.Photo(p.uuid) for p in photos]
        album.add(ps_photos)
        print(f"  Added {len(ps_photos)} photos to preview album.")

        # Open Photos app to the album
        subprocess.run(["open", "-a", "Photos"])
        print()
        print(f"  >> Open Photos and look at the album \"{preview_name}\"")
        print(f"  >> Remove any photos you don't want (select and hit Delete).")
        print(f"  >> When done reviewing, come back here.")
        print()

        try:
            response = input("  Upload to Meural? [y/n]: ").strip().lower()
        except EOFError:
            response = "n"

        if response != "y":
            print("  Cancelled. The preview album is still in Photos if you want to browse it.")
            return

        # Read back the album to see what the user kept
        remaining_uuids = set()
        try:
            for ps_photo in album.photos():
                remaining_uuids.add(ps_photo.uuid)
        except Exception:
            # If we can't read back, fall through with original set
            remaining_uuids = original_uuids

        removed = len(original_uuids) - len(remaining_uuids)
        if removed > 0:
            photos = [p for p in photos if p.uuid in remaining_uuids]
            print(f"  You removed {removed} photos. Uploading {len(photos)}.")
        else:
            print(f"  Uploading all {len(photos)} photos.")

        # Clean up preview album
        try:
            photos_app.delete_album(album)
        except Exception:
            pass
        print("  Preview album removed from Photos.")
        print()

    # Step 5: Upload to Meural
    password = get_meural_password()
    meural = MeuralClient(config["meural_email"], password)

    # Auto-detect device if not specified
    device_id = args.device
    if not device_id:
        devices = meural.get_devices()
        if devices:
            device_id = devices[0]["id"]
            print(f'  Auto-selected device: {devices[0].get("name", device_id)}')

    gallery_id = upload_to_meural(
        meural, photos, engine,
        gallery_name=plan["gallery_name"],
        orientation=plan.get("orientation", "vertical"),
        device_id=device_id,
    )

    print(f"\n  Done! Gallery '{plan['gallery_name']}' created with {len(photos)} photos.")
    if device_id:
        print(f"  Gallery loaded on your Meural device.")
    print()


if __name__ == "__main__":
    main()
